# To validate, run:
#   'git ls-files -i --exclude-standard'

# build generated files
/include/hbverbld.h
bin/*/
lib/*/
obj
.hbmk/
*.hbl
*.hbd
*.hbr
*.hrb

# 'install'-ed binaries
*.exe
*.dll
*.dxe
*.dylib
*.so
*.sl
*.lib
*.a

# packages
/pkg/

# not hosted contribs
/addons/

# misc junk
.DS_Store
*.bak

# exceptions
!libunicows.a
!unicows.lib
!lib/3rd
!config/*.exe
!/*.exe

# VSCode files
.vscode
*.code-workspace
build.log

# Claude Code session data (transcripts, settings)
/.claude/

# Built transpiler binary (produced by src/transpiler/build.sh)
/bin/hbtranspiler

# Transpiler scratch state — rebuilt every scan pass, read only by
# the same run's emit. Content is a function of the test .prg set,
# so tracking it produces noisy diffs without adding any assertion
# value beyond what the .prg change itself says. Determinism is
# covered by src/transpiler/tests/verifyreftab.sh.
/src/transpiler/hbreftab.tab
