#include "astype.ch"
PROCEDURE main()

   // /* some comment*/
   // procedure main()
   //     ? "hello"
   // return

   // Single line comment
   // trailing comment
   LOCAL x := 5 AS INTEGER
   * Star comment
   NOTE Old comment
   /*x for sex is NB*/
   && dBASE commentd
   x += 1

   /* Standalone
      multi-line comment */
   SetColor('"W/B" // after command')

   QOut("Amazing success!")

RETURN

